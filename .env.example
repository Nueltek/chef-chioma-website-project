# ===================================
# CHEF CHIOMA WEBSITE - ENVIRONMENT VARIABLES
# ===================================

# SECURITY NOTE: Never commit your actual .env file to version control
# Copy this file to .env.local for development

# ===================================
# DATABASE (Required)
# ===================================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/chef-chioma

# ===================================
# AUTHENTICATION (Required)
# ===================================
# Generate a secure secret: openssl rand -base64 32
# IMPORTANT: Use a strong, unique secret in production!
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl

# Must match your actual URL (no trailing slash)
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000

# ===================================
# ADMIN CREDENTIALS
# ===================================
# IMPORTANT: Change these for production!
# Use a strong password (min 12 characters, mixed case, numbers, symbols)
ADMIN_EMAIL=chef@chiomaokonkwo.com
ADMIN_PASSWORD=chefchioma123

# ===================================
# IMAGE HOSTING - Cloudinary (Required for image uploads)
# ===================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ===================================
# RICH TEXT EDITOR - TinyMCE (Required for blog editor)
# ===================================
# Get free API key at: https://www.tiny.cloud/
NEXT_PUBLIC_TINYMCE_API_KEY=your-tinymce-key

# ===================================
# PRODUCTION CHECKLIST
# ===================================
# Before deploying to production:
# 1. Generate a new NEXTAUTH_SECRET using: openssl rand -base64 32
# 2. Change ADMIN_EMAIL and ADMIN_PASSWORD to secure values
# 3. Set NEXTAUTH_URL to your production domain
# 4. Enable HTTPS on your domain
# 5. Set up proper CORS headers if needed
# 6. Consider adding rate limiting at CDN/proxy level
